CC = gcc
CFLAGS = -Wall -Wextra -O2 -std=c11 -DWIN32_LEAN_AND_MEAN
LDFLAGS = -lssl -lcrypto -lsqlite3 -lws2_32

TARGET = smb_encrypt_proxy.exe
SRCS = main.c smb_server.c crypto.c auth.c session.c logger.c bench.c lru_cache.c entropy.c ransomware_detector.c behavior_learning.c
OBJS = $(SRCS:.c=.o)

.PHONY: all clean

all: $(TARGET)

$(TARGET): $(OBJS)
	$(CC) $(CFLAGS) -o $@ $^ $(LDFLAGS)

%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@

clean:
	del /Q *.o $(TARGET)
