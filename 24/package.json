{
  "name": "audio-fft-spectrum",
  "version": "1.0.0",
  "description": "Real-time audio spectrum analyzer with React + WebAssembly FFT + WebSocket",
  "main": "server/index.js",
  "scripts": {
    "build:fft": "cmake-js compile --directory cpp",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon server/index.js",
    "dev:client": "webpack serve --mode development",
    "build": "webpack --mode production",
    "start": "node server/index.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "ws": "^8.14.2",
    "better-sqlite3": "^9.4.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.22.0",
    "@babel/preset-env": "^7.22.0",
    "@babel/preset-react": "^7.22.0",
    "babel-loader": "^9.1.2",
    "css-loader": "^6.8.1",
    "html-webpack-plugin": "^5.5.0",
    "style-loader": "^3.3.3",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.0",
    "concurrently": "^8.2.0",
    "nodemon": "^3.0.1",
    "worker-loader": "^3.0.8"
  }
}
