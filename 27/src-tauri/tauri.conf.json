{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PointCloud WebRTC",
  "version": "0.1.0",
  "identifier": "com.pointcloud.webrtc",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "PointCloud WebRTC",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "msi", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Point Cloud WebRTC Transmission",
    "longDescription": "A desktop application for transmitting point cloud data (PLY format) between two clients using WebRTC DataChannel, with real-time Three.js rendering."
  },
  "plugins": {}
}
