@page "/offline-logs"
@using IndustrialDataCollector.Api.Services
@using IndustrialDataCollector.Core.DTOs
@inject IDeviceApiService DeviceApi

<PageTitle>离线日志</PageTitle>

<div class="container-fluid mt-3">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="mb-0">离线日志</h3>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <div class="row">
                <div class="col-md-4">
                    <label class="form-label">选择设备</label>
                    <select class="form-select" @bind="selectedDeviceId" @bind:event="onchange">
                        <option value="0">全部设备</option>
                        @foreach (var device in devices)
                        {
                            <option value="@device.Id">@device.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">&nbsp;</label>
                    <button class="btn btn-primary w-100" @onclick="LoadLogs">
                        刷新
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            @if (isLoading)
            {
                <p>加载中...</p>
            }
            else if (!offlineLogs.Any())
            {
                <div class="text-center py-5">
                    <p>暂无离线日志</p>
                </div>
            }
            else
            {
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>设备名称</th>
                            <th>IP地址</th>
                            <th>离线时间</th>
                            <th>重连时间</th>
                            <th>持续时间</th>
                            <th>重连次数</th>
                            <th>原因</th>
                            <th>状态</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in offlineLogs)
                        {
                            <tr>
                                <td>@log.Id</td>
                                <td>@log.DeviceName</td>
                                <td>@log.IpAddress:@log.Port</td>
                                <td>@log.OfflineAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                <td>@log.ReconnectedAt?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-"</td>
                                <td>@log.Duration?.ToString(@"hh\:mm\:ss") ?? "-"</td>
                                <td>@log.ReconnectAttempts</td>
                                <td>@log.Reason</td>
                                <td>
                                    <span class="badge @(log.IsResolved ? "bg-success" : "bg-warning text-dark")">
                                        @(log.IsResolved ? "已恢复" : "未恢复")
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>

@code {
    private IEnumerable<DeviceDto> devices = Enumerable.Empty<DeviceDto>();
    private IEnumerable<OfflineLogDto> offlineLogs = Enumerable.Empty<OfflineLogDto>();
    private bool isLoading = true;
    private int selectedDeviceId;

    protected override async Task OnInitializedAsync()
    {
        devices = await DeviceApi.GetDevicesAsync();
        await LoadLogs();
    }

    private async Task LoadLogs()
    {
        isLoading = true;
        offlineLogs = selectedDeviceId > 0
            ? await DeviceApi.GetOfflineLogsAsync(selectedDeviceId)
            : await DeviceApi.GetOfflineLogsAsync();
        isLoading = false;
        StateHasChanged();
    }
}
