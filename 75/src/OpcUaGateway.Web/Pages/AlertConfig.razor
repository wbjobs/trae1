@page "/alerts"
@using System.Net.Http
@using System.Net.Http.Json
@using OpcUaGateway.Core.DTOs
@using OpcUaGateway.Core.Models
@inject HttpClient httpClient

<h1 class="mb-4">告警配置</h1>

<h3 class="mb-3">活跃告警</h3>

@if (activeAlerts == null)
{
    <p><em>Loading...</em></p>
}
else if (activeAlerts.Count == 0)
{
    <div class="alert alert-info">
        暂无活跃告警
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-danger">
                <tr>
                    <th>告警ID</th>
                    <th>设备</th>
                    <th>点位</th>
                    <th>告警类型</th>
                    <th>阈值</th>
                    <th>实际值</th>
                    <th>触发时间</th>
                    <th>状态</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var alert in activeAlerts)
                {
                    <tr>
                        <td>@alert.AlertId</td>
                        <td>@alert.DeviceId</td>
                        <td>@alert.PointName</td>
                        <td>
                            <span class="badge @GetAlertTypeBadge(alert.AlertType)">@alert.AlertType</span>
                        </td>
                        <td>@alert.ThresholdValue:F2</td>
                        <td><strong>@alert.ActualValue:F2</strong></td>
                        <td>@alert.TriggerTime.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td>
                            @if (alert.IsAcknowledged)
                            {
                                <span class="badge bg-success">已确认</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">待确认</span>
                            }
                        </td>
                        <td>
                            @if (!alert.IsAcknowledged)
                            {
                                <button class="btn btn-sm btn-success" @onclick="() => AcknowledgeAlert(alert.AlertId)">
                                    确认
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<h3 class="mt-5 mb-3">历史告警</h3>

<div class="mb-3">
    <label>查询时间范围（小时）：</label>
    <select class="form-select form-select-sm d-inline-block" style="width: auto;" @bind="historyHours" @onchange="LoadHistoryAsync">
        <option value="1">最近1小时</option>
        <option value="6">最近6小时</option>
        <option value="24" selected>最近24小时</option>
        <option value="72">最近3天</option>
        <option value="168">最近7天</option>
    </select>
</div>

@if (alertHistory == null)
{
    <p><em>Loading...</em></p>
}
else if (alertHistory.Count == 0)
{
    <div class="alert alert-info">
        暂无历史告警记录
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>告警ID</th>
                    <th>设备</th>
                    <th>点位</th>
                    <th>告警类型</th>
                    <th>阈值</th>
                    <th>实际值</th>
                    <th>触发时间</th>
                    <th>消息</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var alert in alertHistory)
                {
                    <tr>
                        <td>@alert.AlertId</td>
                        <td>@alert.DeviceId</td>
                        <td>@alert.PointName</td>
                        <td>
                            <span class="badge @GetAlertTypeBadge(alert.AlertType)">@alert.AlertType</span>
                        </td>
                        <td>@alert.ThresholdValue:F2</td>
                        <td>@alert.ActualValue:F2</td>
                        <td>@alert.TriggerTime.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td><small>@alert.Message</small></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<AlertDto>? activeAlerts;
    private List<AlertDto>? alertHistory;
    private int historyHours = 24;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        activeAlerts = await httpClient.GetFromJsonAsync<List<AlertDto>>("api/alerts/active");
        await LoadHistoryAsync();
    }

    private async Task LoadHistoryAsync()
    {
        alertHistory = await httpClient.GetFromJsonAsync<List<AlertDto>>($"api/alerts/history?hours={historyHours}");
    }

    private async Task AcknowledgeAlert(string alertId)
    {
        try
        {
            await httpClient.PostAsync($"api/alerts/{alertId}/acknowledge", null);
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error acknowledging alert: {ex.Message}");
        }
    }

    private string GetAlertTypeBadge(string alertType)
    {
        return alertType switch
        {
            "UpperLimit" => "bg-danger",
            "LowerLimit" => "bg-warning text-dark",
            "RateOfChange" => "bg-info",
            _ => "bg-secondary"
        };
    }
}