@page "/certificates"
@using System.Net.Http
@using System.Net.Http.Json
@using OpcUaGateway.Core.DTOs
@inject HttpClient httpClient

<h1 class="mb-4">证书管理</h1>

<div class="row">
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h5>证书策略配置</h5>
            </div>
            <div class="card-body">
                @if (certConfig != null)
                {
                    <div class="mb-3">
                        <label>接受策略</label>
                        <select class="form-select" @bind="certConfig.AcceptanceStrategy" @onchange="OnStrategyChanged">
                            @if (strategies != null)
                            {
                                @foreach (var s in strategies)
                                {
                                    <option value="@s">@GetStrategyDisplayName(s)</option>
                                }
                            }
                        </select>
                        <small class="text-muted">@GetStrategyDescription(certConfig.AcceptanceStrategy)</small>
                    </div>
                    <div class="mb-3">
                        <label>过期预警天数</label>
                        <InputNumber class="form-control" @bind-Value="certConfig.ExpiryWarningDays" />
                    </div>
                    <div class="mb-3">
                        <label>证书变更时自动重新协商</label>
                        <InputCheckbox class="form-check-input" @bind-Value="certConfig.AutoRenegotiateOnChange" />
                    </div>
                    <div class="mb-3">
                        <label>审计日志保留天数</label>
                        <InputNumber class="form-control" @bind-Value="certConfig.AuditLogRetentionDays" />
                    </div>
                    <button class="btn btn-primary" @onclick="SaveConfig">保存配置</button>
                }
                else
                {
                    <p><em>Loading...</em></p>
                }
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5>证书白名单</h5>
                <button class="btn btn-sm btn-primary" @onclick="ShowAddWhitelistForm">
                    <span class="oi oi-plus"></span> 添加
                </button>
            </div>
            <div class="card-body">
                @if (showAddWhitelist)
                {
                    <div class="card bg-light mb-3">
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-4 mb-2">
                                    <label>指纹 (Thumbprint)</label>
                                    <InputText class="form-control" @bind-Value="whitelistForm.Thumbprint" />
                                </div>
                                <div class="col-md-4 mb-2">
                                    <label>主题 (Subject)</label>
                                    <InputText class="form-control" @bind-Value="whitelistForm.Subject" />
                                </div>
                                <div class="col-md-4 mb-2">
                                    <label>设备ID</label>
                                    <InputText class="form-control" @bind-Value="whitelistForm.DeviceId" />
                                </div>
                                <div class="col-md-4 mb-2">
                                    <label>颁发者 (Issuer)</label>
                                    <InputText class="form-control" @bind-Value="whitelistForm.Issuer" />
                                </div>
                                <div class="col-md-4 mb-2">
                                    <label>过期时间</label>
                                    <InputDate class="form-control" @bind-Value="whitelistForm.NotAfter" />
                                </div>
                                <div class="col-md-4 mb-2">
                                    <label>描述</label>
                                    <InputText class="form-control" @bind-Value="whitelistForm.Description" />
                                </div>
                            </div>
                            <button class="btn btn-success" @onclick="SaveWhitelist">保存</button>
                            <button class="btn btn-secondary" @onclick="HideAddWhitelistForm">取消</button>
                        </div>
                    </div>
                }

                @if (whitelist == null)
                {
                    <p><em>Loading...</em></p>
                }
                else if (whitelist.Count == 0)
                {
                    <div class="alert alert-info">暂无白名单条目</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>设备ID</th>
                                    <th>主题</th>
                                    <th>指纹</th>
                                    <th>过期时间</th>
                                    <th>状态</th>
                                    <th>操作</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var entry in whitelist)
                                {
                                    <tr>
                                        <td>@entry.Id</td>
                                        <td>@entry.DeviceId</td>
                                        <td><small>@entry.Subject</small></td>
                                        <td><code>@entry.Thumbprint.Substring(0, Math.Min(20, entry.Thumbprint.Length))...</code></td>
                                        <td>@entry.NotAfter.ToString("yyyy-MM-dd")</td>
                                        <td>
                                            @if (entry.IsEnabled)
                                            {
                                                <span class="badge bg-success">启用</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">禁用</span>
                                            }
                                        </td>
                                        <td>
                                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteWhitelist(entry.Id)">
                                                删除
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<h3 class="mt-5 mb-3">证书审计日志</h3>

<div class="mb-3">
    <label>查询时间范围（小时）：</label>
    <select class="form-select form-select-sm d-inline-block" style="width: auto;" @bind="auditHours" @onchange="LoadAuditLogsAsync">
        <option value="1">最近1小时</option>
        <option value="6">最近6小时</option>
        <option value="24" selected>最近24小时</option>
        <option value="72">最近3天</option>
        <option value="168">最近7天</option>
        <option value="720">最近30天</option>
    </select>
    <button class="btn btn-sm btn-secondary ms-2" @onclick="LoadAuditLogsAsync">刷新</button>
</div>

@if (auditLogs == null)
{
    <p><em>Loading...</em></p>
}
else if (auditLogs.Count == 0)
{
    <div class="alert alert-info">暂无审计日志记录</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>时间</th>
                    <th>设备</th>
                    <th>事件类型</th>
                    <th>主题</th>
                    <th>指纹</th>
                    <th>策略</th>
                    <th>结果</th>
                    <th>详情</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in auditLogs)
                {
                    <tr>
                        <td>@log.EventTime.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td>@log.DeviceName</td>
                        <td>
                            <span class="badge @GetEventTypeBadge(log.EventType)">@log.EventType</span>
                        </td>
                        <td><small>@log.Subject</small></td>
                        <td><code>@log.Thumbprint.Substring(0, Math.Min(16, log.Thumbprint.Length))...</code></td>
                        <td>@log.StrategyUsed</td>
                        <td>
                            @if (log.IsAccepted)
                            {
                                <span class="badge bg-success">已接受</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">已拒绝</span>
                            }
                        </td>
                        <td><small>@log.Details</small></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private CertificateConfigDto? certConfig;
    private List<string>? strategies;
    private List<CertificateWhitelistDto>? whitelist;
    private List<CertificateAuditLogDto>? auditLogs;
    private WhitelistAddDto whitelistForm = new();
    private bool showAddWhitelist;
    private int auditHours = 24;

    protected override async Task OnInitializedAsync()
    {
        await LoadConfigAsync();
        await LoadStrategiesAsync();
        await LoadWhitelistAsync();
        await LoadAuditLogsAsync();
    }

    private async Task LoadConfigAsync()
    {
        certConfig = await httpClient.GetFromJsonAsync<CertificateConfigDto>("api/certificates/config");
    }

    private async Task LoadStrategiesAsync()
    {
        strategies = await httpClient.GetFromJsonAsync<List<string>>("api/certificates/strategies");
    }

    private async Task LoadWhitelistAsync()
    {
        whitelist = await httpClient.GetFromJsonAsync<List<CertificateWhitelistDto>>("api/certificates/whitelist");
    }

    private async Task LoadAuditLogsAsync()
    {
        auditLogs = await httpClient.GetFromJsonAsync<List<CertificateAuditLogDto>>($"api/certificates/audit?hours={auditHours}");
    }

    private async Task SaveConfig()
    {
        if (certConfig != null)
        {
            await httpClient.PutAsJsonAsync("api/certificates/strategy", certConfig);
        }
    }

    private void OnStrategyChanged(ChangeEventArgs e)
    {
        if (certConfig != null)
        {
            certConfig.AcceptanceStrategy = e.Value?.ToString() ?? "AutoTrustAll";
        }
    }

    private string GetStrategyDisplayName(string strategy)
    {
        return strategy switch
        {
            "AutoTrustAll" => "自动信任所有证书",
            "WhitelistOnly" => "仅信任白名单",
            "ManualConfirmation" => "手动确认",
            _ => strategy
        };
    }

    private string GetStrategyDescription(string strategy)
    {
        return strategy switch
        {
            "AutoTrustAll" => "自动接受所有服务器证书，包括自签名和过期证书",
            "WhitelistOnly" => "只接受白名单中的证书指纹，其他证书一律拒绝",
            "ManualConfirmation" => "新证书需要管理员手动确认后才会被接受",
            _ => string.Empty
        };
    }

    private string GetEventTypeBadge(string eventType)
    {
        return eventType switch
        {
            "CertificateAccepted" => "bg-success",
            "CertificateRejected" => "bg-danger",
            "CertificateChanged" => "bg-warning text-dark",
            "CertificateExpired" => "bg-danger",
            "CertificateRenewed" => "bg-info",
            _ => "bg-secondary"
        };
    }

    private void ShowAddWhitelistForm()
    {
        whitelistForm = new WhitelistAddDto { NotAfter = DateTime.UtcNow.AddYears(1) };
        showAddWhitelist = true;
    }

    private void HideAddWhitelistForm()
    {
        showAddWhitelist = false;
    }

    private async Task SaveWhitelist()
    {
        await httpClient.PostAsJsonAsync("api/certificates/whitelist", whitelistForm);
        showAddWhitelist = false;
        await LoadWhitelistAsync();
    }

    private async Task DeleteWhitelist(long id)
    {
        await httpClient.DeleteAsync($"api/certificates/whitelist/{id}");
        await LoadWhitelistAsync();
    }
}