@page "/devices"
@using System.Net.Http
@using System.Net.Http.Json
@using OpcUaGateway.Core.DTOs
@using OpcUaGateway.Core.Models
@inject HttpClient httpClient
@inject NavigationManager NavigationManager

<h1 class="mb-4">设备管理</h1>

<div class="mb-3">
    <button class="btn btn-primary" @onclick="ShowAddForm">
        <span class="oi oi-plus"></span> 添加设备
    </button>
</div>

@if (showForm)
{
    <div class="card mb-4">
        <div class="card-header">
            <h5>@(isEdit ? "编辑设备" : "添加设备")</h5>
        </div>
        <div class="card-body">
            <EditForm Model="@deviceForm" OnValidSubmit="SaveDevice">
                <DataAnnotationsValidator />
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label>设备名称</label>
                        <InputText class="form-control" @bind-Value="deviceForm.DeviceName" placeholder="请输入设备名称" />
                        <ValidationMessage For="@(() => deviceForm.DeviceName)" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label>端点URL</label>
                        <InputText class="form-control" @bind-Value="deviceForm.EndpointUrl" placeholder="opc.tcp://192.168.1.100:4840" />
                        <ValidationMessage For="@(() => deviceForm.EndpointUrl)" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label>用户名</label>
                        <InputText class="form-control" @bind-Value="deviceForm.Username" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label>密码</label>
                        <InputText type="password" class="form-control" @bind-Value="deviceForm.Password" />
                    </div>
                    <div class="col-md-2 mb-3">
                        <label>采集间隔(ms)</label>
                        <InputNumber class="form-control" @bind-Value="deviceForm.PollIntervalMs" />
                    </div>
                    <div class="col-md-2 mb-3">
                        <label>启用安全</label>
                        <InputCheckbox class="form-check-input" @bind-Value="deviceForm.UseSecurity" />
                    </div>
                    <div class="col-md-2 mb-3">
                        <label>启用</label>
                        <InputCheckbox class="form-check-input" @bind-Value="deviceForm.IsEnabled" />
                    </div>
                </div>
                <div>
                    <button type="submit" class="btn btn-primary">保存</button>
                    <button type="button" class="btn btn-secondary" @onclick="HideForm">取消</button>
                </div>
            </EditForm>
        </div>
    </div>
}

@if (devices == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>设备ID</th>
                    <th>设备名称</th>
                    <th>端点URL</th>
                    <th>采集间隔</th>
                    <th>点位数量</th>
                    <th>状态</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var device in devices)
                {
                    <tr>
                        <td>@device.DeviceId</td>
                        <td>@device.DeviceName</td>
                        <td><code>@device.EndpointUrl</code></td>
                        <td>@device.PollIntervalMs ms</td>
                        <td>@device.DataPoints?.Count</td>
                        <td>
                            @if (device.IsEnabled)
                            {
                                <span class="badge bg-success">启用</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">禁用</span>
                            }
                        </td>
                        <td>
                            <button class="btn btn-sm btn-info me-1" @onclick="() => EditDevice(device)">
                                编辑
                            </button>
                            <button class="btn btn-sm btn-warning me-1" @onclick="() => ViewPoints(device)">
                                点位
                            </button>
                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteDevice(device)">
                                删除
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<Device>? devices;
    private DeviceConfigDto deviceForm = new();
    private bool showForm;
    private bool isEdit;
    private string? editingDeviceId;

    protected override async Task OnInitializedAsync()
    {
        await LoadDevicesAsync();
    }

    private async Task LoadDevicesAsync()
    {
        devices = await httpClient.GetFromJsonAsync<List<Device>>("api/devices");
    }

    private void ShowAddForm()
    {
        deviceForm = new DeviceConfigDto
        {
            PollIntervalMs = 100,
            IsEnabled = true
        };
        showForm = true;
        isEdit = false;
        editingDeviceId = null;
    }

    private void EditDevice(Device device)
    {
        deviceForm = new DeviceConfigDto
        {
            DeviceName = device.DeviceName,
            EndpointUrl = device.EndpointUrl,
            Username = device.Username,
            Password = device.Password,
            UseSecurity = device.UseSecurity,
            IsEnabled = device.IsEnabled,
            PollIntervalMs = device.PollIntervalMs
        };
        showForm = true;
        isEdit = true;
        editingDeviceId = device.DeviceId;
    }

    private void ViewPoints(Device device)
    {
        NavigationManager.NavigateTo($"/datapoints/{device.DeviceId}");
    }

    private async Task SaveDevice()
    {
        try
        {
            if (isEdit && editingDeviceId != null)
            {
                await httpClient.PutAsJsonAsync($"api/devices/{editingDeviceId}", deviceForm);
            }
            else
            {
                await httpClient.PostAsJsonAsync("api/devices", deviceForm);
            }
            await LoadDevicesAsync();
            HideForm();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving device: {ex.Message}");
        }
    }

    private void HideForm()
    {
        showForm = false;
    }

    private async Task DeleteDevice(Device device)
    {
        try
        {
            await httpClient.DeleteAsync($"api/devices/{device.DeviceId}");
            await LoadDevicesAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting device: {ex.Message}");
        }
    }
}