@page "/"
@using System.Net.Http
@using System.Net.Http.Json
@using OpcUaGateway.Core.DTOs
@using OpcUaGateway.Core.Models
@inject HttpClient httpClient

<h1 class="mb-4">设备状态仪表盘</h1>

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card bg-success text-white">
            <div class="card-body">
                <h6 class="card-title">在线设备</h6>
                <h2 class="card-text">@onlineCount</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-danger text-white">
            <div class="card-body">
                <h6 class="card-title">离线设备</h6>
                <h2 class="card-text">@offlineCount</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-warning text-dark">
            <div class="card-body">
                <h6 class="card-title">活跃告警</h6>
                <h2 class="card-text">@alertCount</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-info text-white">
            <div class="card-body">
                <h6 class="card-title">采集点位</h6>
                <h2 class="card-text">@totalPoints</h2>
            </div>
        </div>
    </div>
</div>

<h3 class="mb-3">设备列表</h3>

@if (deviceStatuses == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>设备ID</th>
                    <th>设备名称</th>
                    <th>状态</th>
                    <th>连接</th>
                    <th>最后采集时间</th>
                    <th>成功次数</th>
                    <th>失败次数</th>
                    <th>错误信息</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var status in deviceStatuses)
                {
                    <tr>
                        <td>@status.DeviceId</td>
                        <td>@status.DeviceName</td>
                        <td>
                            <span class="badge @GetStatusBadgeClass(status.Status)">@status.Status</span>
                        </td>
                        <td>
                            @if (status.IsConnected)
                            {
                                <span class="badge bg-success">已连接</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">未连接</span>
                            }
                        </td>
                        <td>@status.LastSuccessfulCollectTime.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td>@status.SuccessfulCollectCount</td>
                        <td>@status.FailedCollectCount</td>
                        <td>
                            @if (!string.IsNullOrEmpty(status.ErrorMessage))
                            {
                                <small class="text-danger">@status.ErrorMessage</small>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<DeviceStatusDto>? deviceStatuses;
    private int onlineCount;
    private int offlineCount;
    private int alertCount;
    private int totalPoints;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            deviceStatuses = await httpClient.GetFromJsonAsync<List<DeviceStatusDto>>("api/devices/statuses");

            if (deviceStatuses != null)
            {
                onlineCount = deviceStatuses.Count(s => s.Status == "Online");
                offlineCount = deviceStatuses.Count(s => s.Status != "Online");
            }

            var alerts = await httpClient.GetFromJsonAsync<List<AlertDto>>("api/alerts/active");
            alertCount = alerts?.Count ?? 0;

            var devices = await httpClient.GetFromJsonAsync<List<Device>>("api/devices");
            totalPoints = devices?.Sum(d => d.DataPoints?.Count ?? 0) ?? 0;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading data: {ex.Message}");
        }
    }

    private string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Online" => "bg-success",
            "Offline" => "bg-danger",
            "Error" => "bg-warning text-dark",
            _ => "bg-secondary"
        };
    }
}