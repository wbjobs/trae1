@page "/datapoints"
@page "/datapoints/{deviceId}"
@using System.Net.Http
@using System.Net.Http.Json
@using OpcUaGateway.Core.DTOs
@using OpcUaGateway.Core.Models
@inject HttpClient httpClient

<h1 class="mb-4">点位映射管理</h1>

<div class="mb-3">
    <label>选择设备：</label>
    <select class="form-select form-select-lg" @bind="selectedDeviceId" @onchange="OnDeviceChanged">
        <option value="">-- 请选择设备 --</option>
        @if (devices != null)
        {
            @foreach (var device in devices)
            {
                <option value="@device.DeviceId">@device.DeviceName (@device.DeviceId)</option>
            }
        }
    </select>
</div>

@if (!string.IsNullOrEmpty(selectedDeviceId))
{
    <div class="mb-3">
        <button class="btn btn-primary" @onclick="ShowAddForm">
            <span class="oi oi-plus"></span> 添加点位
        </button>
    </div>

    if (showForm)
    {
        <div class="card mb-4">
            <div class="card-header">
                <h5>@(isEdit ? "编辑点位" : "添加点位")</h5>
            </div>
            <div class="card-body">
                <EditForm Model="@pointForm" OnValidSubmit="SavePoint">
                    <DataAnnotationsValidator />
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label>节点ID</label>
                            <InputText class="form-control" @bind-Value="pointForm.NodeId" placeholder="ns=2;s=Channel1.Device1.Tag1" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label>点位名称</label>
                            <InputText class="form-control" @bind-Value="pointForm.PointName" placeholder="温度1" />
                        </div>
                        <div class="col-md-2 mb-3">
                            <label>数据类型</label>
                            <InputSelect class="form-control" @bind-Value="pointForm.DataType">
                                <option value="Double">Double</option>
                                <option value="Float">Float</option>
                                <option value="Int32">Int32</option>
                                <option value="Int16">Int16</option>
                                <option value="Bool">Bool</option>
                            </InputSelect>
                        </div>
                        <div class="col-md-2 mb-3">
                            <label>单位</label>
                            <InputText class="form-control" @bind-Value="pointForm.Unit" placeholder="℃" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label>描述</label>
                            <InputText class="form-control" @bind-Value="pointForm.Description" />
                        </div>
                        <div class="col-md-2 mb-3">
                            <label>启用</label>
                            <InputCheckbox class="form-check-input" @bind-Value="pointForm.IsEnabled" />
                        </div>
                    </div>
                    <hr />
                    <h6>阈值配置</h6>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label>上限阈值</label>
                            <InputNumber class="form-control" @bind-Value="pointForm.UpperThreshold" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label>下限阈值</label>
                            <InputNumber class="form-control" @bind-Value="pointForm.LowerThreshold" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label>变化率阈值</label>
                            <InputNumber class="form-control" @bind-Value="pointForm.RateOfChangeThreshold" />
                        </div>
                    </div>
                    <div>
                        <button type="submit" class="btn btn-primary">保存</button>
                        <button type="button" class="btn btn-secondary" @onclick="HideForm">取消</button>
                    </div>
                </EditForm>
            </div>
        </div>
    }

    if (dataPoints == null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>点位ID</th>
                        <th>节点ID</th>
                        <th>点位名称</th>
                        <th>数据类型</th>
                        <th>单位</th>
                        <th>上限阈值</th>
                        <th>下限阈值</th>
                        <th>启用</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var point in dataPoints)
                    {
                        <tr>
                            <td>@point.PointId</td>
                            <td><code>@point.NodeId</code></td>
                            <td>@point.PointName</td>
                            <td>@point.DataType</td>
                            <td>@point.Unit</td>
                            <td>@point.UpperThreshold</td>
                            <td>@point.LowerThreshold</td>
                            <td>
                                @if (point.IsEnabled)
                                {
                                    <span class="badge bg-success">是</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">否</span>
                                }
                            </td>
                            <td>
                                <button class="btn btn-sm btn-info me-1" @onclick="() => EditPoint(point)">
                                    编辑
                                </button>
                                <button class="btn btn-sm btn-danger" @onclick="() => DeletePoint(point)">
                                    删除
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@code {
    [Parameter]
    public string? DeviceId { get; set; }

    private List<Device>? devices;
    private List<DataPoint>? dataPoints;
    private string? selectedDeviceId;
    private DataPointDto pointForm = new();
    private bool showForm;
    private bool isEdit;
    private string? editingPointId;

    protected override async Task OnInitializedAsync()
    {
        devices = await httpClient.GetFromJsonAsync<List<Device>>("api/devices");

        if (!string.IsNullOrEmpty(DeviceId))
        {
            selectedDeviceId = DeviceId;
            await LoadDataPointsAsync();
        }
    }

    private async Task OnDeviceChanged(ChangeEventArgs e)
    {
        selectedDeviceId = e.Value?.ToString();
        await LoadDataPointsAsync();
    }

    private async Task LoadDataPointsAsync()
    {
        if (string.IsNullOrEmpty(selectedDeviceId)) return;

        dataPoints = await httpClient.GetFromJsonAsync<List<DataPoint>>($"api/datapoints/{selectedDeviceId}");
    }

    private void ShowAddForm()
    {
        pointForm = new DataPointDto
        {
            DataType = "Double",
            IsEnabled = true
        };
        showForm = true;
        isEdit = false;
        editingPointId = null;
    }

    private void EditPoint(DataPoint point)
    {
        pointForm = new DataPointDto
        {
            NodeId = point.NodeId,
            PointName = point.PointName,
            DataType = point.DataType,
            Unit = point.Unit,
            Description = point.Description,
            IsEnabled = point.IsEnabled,
            UpperThreshold = point.UpperThreshold,
            LowerThreshold = point.LowerThreshold,
            RateOfChangeThreshold = point.RateOfChangeThreshold
        };
        showForm = true;
        isEdit = true;
        editingPointId = point.PointId;
    }

    private async Task SavePoint()
    {
        try
        {
            if (isEdit && editingPointId != null)
            {
                await httpClient.PutAsJsonAsync($"api/datapoints/{selectedDeviceId}/{editingPointId}", pointForm);
            }
            else
            {
                await httpClient.PostAsJsonAsync($"api/datapoints/{selectedDeviceId}", pointForm);
            }
            await LoadDataPointsAsync();
            HideForm();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving point: {ex.Message}");
        }
    }

    private void HideForm()
    {
        showForm = false;
    }

    private async Task DeletePoint(DataPoint point)
    {
        try
        {
            await httpClient.DeleteAsync($"api/datapoints/{selectedDeviceId}/{point.PointId}");
            await LoadDataPointsAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting point: {ex.Message}");
        }
    }
}