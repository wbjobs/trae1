{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "OpcUaGateway": "Debug"
    }
  },
  "Gateway": {
    "PollIntervalMs": 100,
    "BatchSize": 50,
    "OfflineFlushIntervalMs": 5000,
    "MaxRetryCount": 3,
    "DatabasePath": "gateway_data.db",
    "Mqtt": {
      "BrokerAddress": "localhost",
      "Port": 1883,
      "ClientId": "OpcUaGateway",
      "Username": null,
      "Password": null,
      "TopicPrefix": "factory/gateway",
      "UseTls": false
    },
    "Certificate": {
      "AcceptanceStrategy": "AutoTrustAll",
      "ExpiryWarningDays": 30,
      "AutoRenegotiateOnChange": true,
      "AuditLogRetentionDays": 90
    },
    "Email": {
      "EnableNotifications": true,
      "SmtpServer": "smtp.example.com",
      "SmtpPort": 587,
      "Username": "noreply@example.com",
      "Password": null,
      "UseSsl": true,
      "FromAddress": "noreply@gateway.local",
      "FromName": "OPC UA Gateway",
      "AdminEmails": [ "admin@example.com" ]
    },
    "RuleEngine": {
      "EnableRuleEngine": true,
      "MaxExecutionTimeMs": 5.0,
      "MaxFailCount": 5,
      "PerformanceSampleSize": 1000,
      "AutoDisablePerformanceThresholdMs": 5,
      "EnablePerformanceMonitoring": true
    }
  },
  "AllowedHosts": "*"
}