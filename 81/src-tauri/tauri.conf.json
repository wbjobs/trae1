{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VoiceCommand",
  "version": "1.0.0",
  "identifier": "com.voicecommand.app",
  "build": {
    "frontendDist": "../src",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "语音命令词识别系统",
        "width": 960,
        "height": 680,
        "resizable": true,
        "minWidth": 720,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
